<%- include('partials/header', { title: 'Union Citoyenne | Accueil', bodyClass: 'page-home' }) %>

<section class="page-hero page-hero-home">
  <div class="page-hero-copy">
    <p class="eyebrow">Mouvement humaniste réformiste</p>
    <h1>Union Citoyenne</h1>
    <p class="hero-lead">
      Union Citoyenne veut dépasser le clivage gauche-droite pour remettre au centre la dignité
      humaine, la responsabilité individuelle et la démocratie locale.
    </p>
    <p>
      Notre objectif est simple: rendre l'action publique plus proche, plus juste et plus efficace,
      avec des citoyens pleinement acteurs dans les décisions qui touchent leur quotidien.
    </p>
    <div class="hero-actions">
      <a class="button" href="/charte">Découvrir la charte</a>
      <a class="button button-outline" href="/adherer">Adhérer</a>
    </div>
  </div>

  <div class="hero-side">
    <aside class="hero-panel">
      <p class="panel-kicker">Cap politique</p>
      <h2>Redonner du poids aux citoyens et aux territoires</h2>
      <p>
        Une méthode civique, des assemblées locales, une coordination territoriale
        et des piliers concrets pour transformer l'action publique.
      </p>
      <div class="metric-grid">
        <article class="metric-card">
          <strong><%= confirmedCount %></strong>
          <span>adhérents confirmés</span>
        </article>
        <article class="metric-card">
          <strong>7</strong>
          <span>piliers de réforme</span>
        </article>
        <article class="metric-card">
          <strong>3</strong>
          <span>repères fondateurs</span>
        </article>
      </div>
    </aside>

    <figure class="cover-card">
      <img src="/images/cover.jpg" alt="Visuel Union Citoyenne Citoyens Debout" />
      <figcaption>Visuel de référence du mouvement</figcaption>
    </figure>
  </div>
</section>

<section class="themed-section">
  <div class="section-heading">
    <p class="eyebrow">Notre méthode</p>
    <h2>Trois repères pour structurer le projet</h2>
  </div>

  <div class="feature-grid">
    <article class="feature-card">
      <h3>Philosophie</h3>
      <p>Former des citoyens capables de penser par eux-mêmes et de juger avec recul.</p>
    </article>
    <article class="feature-card">
      <h3>Éthique</h3>
      <p>Relier liberté et responsabilité, avec une exigence de dignité pour chacun.</p>
    </article>
    <article class="feature-card">
      <h3>Institutions</h3>
      <p>Organiser des mécanismes clairs pour que les décisions reviennent aux citoyens.</p>
    </article>
  </div>
</section>

<section class="themed-section">
  <div class="section-heading">
    <p class="eyebrow">Fonctionnement</p>
    <h2>Une démocratie qui remonte du terrain</h2>
  </div>

  <div class="timeline-grid">
    <article class="timeline-card">
      <span class="timeline-index">01</span>
      <h3>Assemblées locales</h3>
      <p>Une assemblée citoyenne hebdomadaire dans chaque commune pour débattre et proposer.</p>
    </article>
    <article class="timeline-card">
      <span class="timeline-index">02</span>
      <h3>Coordination régionale</h3>
      <p>Une coordination mensuelle par région pour consolider les priorités du terrain.</p>
    </article>
    <article class="timeline-card">
      <span class="timeline-index">03</span>
      <h3>Référendum national</h3>
      <p>Un référendum citoyen national pour les grands sujets qui engagent l'ensemble du pays.</p>
    </article>
  </div>
</section>

<section class="themed-section">
  <div class="section-heading">
    <p class="eyebrow">Piliers</p>
    <h2>Les axes du projet</h2>
  </div>

  <div class="pillar-grid">
    <% pillars.forEach((pillar) => { %>
      <article class="pillar-card">
        <img class="pillar-card-image" src="<%= pillar.icon %>" alt="Illustration <%= pillar.title %>" />
        <div class="pillar-card-body">
          <h3><%= pillar.title %></h3>
          <p><%= pillar.shortDescription %></p>
          <a class="text-link" href="/piliers/<%= pillar.slug %>">Découvrir ce pilier</a>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="quote-band">
  <img src="/images/logo.png" alt="Logo Union Citoyenne" class="conclusion-logo" />
  <blockquote>Le peuple par le peuple. Le peuple pour le peuple.</blockquote>
  <p class="quote-note">Liberté de penser, liberté de changer, responsabilité individuelle.</p>
</section>

<section class="cta-banner">
  <div>
    <p class="eyebrow">Adhésion</p>
    <h2>Rejoindre la charte</h2>
    <p>Le projet compte déjà <strong><%= confirmedCount %> adhérents confirmés</strong>.</p>
  </div>
  <div class="cta-actions">
    <a class="button" href="/adherer">Adhérer à la charte</a>
  </div>
</section>

<%- include('partials/footer') %>
