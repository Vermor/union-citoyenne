<%- include('partials/header', {
  title: pillar.seoTitle,
  description: pillar.seoDescription,
  bodyClass: 'page-pillar'
}) %>

<section class="page-hero page-hero-compact">
  <div class="page-hero-copy">
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a>
      <span>/</span>
      <a href="/charte">Charte</a>
      <span>/</span>
      <span aria-current="page"><%= pillar.title %></span>
    </nav>
    <h1 class="pillar-title-with-icon">
      <img src="<%= pillar.icon %>" alt="Icone <%= pillar.title %>" class="pillar-icon pillar-icon-lg" />
      <span><%= pillar.title %></span>
    </h1>
    <p class="hero-lead"><%= pillar.intro %></p>
  </div>

  <aside class="hero-panel hero-panel-compact">
    <p class="panel-kicker">Pilier</p>
    <h2>Charte et mise en oeuvre</h2>
    <p>
      Chaque pilier detaille une orientation du projet et la relie a une logique
      institutionnelle, sociale et territoriale.
    </p>
    <a class="button button-outline" href="/charte">Retour a la charte</a>
  </aside>
</section>

<article class="content-stack pillar-page">
  <% pillar.sections.forEach((section) => { %>
    <section class="content-card">
      <h2><%= section.heading %></h2>
      <% section.paragraphs.forEach((paragraph) => { %>
        <p><%= paragraph %></p>
      <% }) %>
      <% if (section.bullets && section.bullets.length) { %>
        <ul>
          <% section.bullets.forEach((bullet) => { %>
            <li><%= bullet %></li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  <% }) %>

  <section class="content-card pillar-navigation">
    <h2>Navigation</h2>
    <div class="pillar-nav-links">
      <a class="button button-outline" href="/charte">Retour a la charte</a>
      <a class="button button-outline" href="/">Retour a l'accueil</a>
    </div>
    <div class="pillar-nav-links">
      <% if (previousPillar) { %>
        <a class="text-link" href="/piliers/<%= previousPillar.slug %>">Pilier precedent</a>
      <% } %>
      <% if (nextPillar) { %>
        <a class="text-link" href="/piliers/<%= nextPillar.slug %>">Pilier suivant</a>
      <% } %>
    </div>
    <h3>Voir les autres piliers</h3>
    <ul class="other-pillars-list">
      <% pillars.forEach((item) => { if (item.slug !== pillar.slug) { %>
        <li><a class="text-link" href="/piliers/<%= item.slug %>"><%= item.title %></a></li>
      <% } }) %>
    </ul>
  </section>
</article>

<%- include('partials/footer') %>
