<%- include('partials/header', {
  title: pillar.seoTitle,
  description: pillar.seoDescription
}) %>

<nav class="breadcrumb" aria-label="Fil d'Ariane">
  <a href="/">Accueil</a>
  <span>/</span>
  <a href="/charte">Charte</a>
  <span>/</span>
  <span aria-current="page"><%= pillar.title %></span>
</nav>

<article class="pillar-page">
  <header class="section-block">
    <h1 class="pillar-title-with-icon">
      <img src="<%= pillar.icon %>" alt="Icône <%= pillar.title %>" class="pillar-icon pillar-icon-lg" />
      <span><%= pillar.title %></span>
    </h1>
    <p class="pillar-intro"><%= pillar.intro %></p>
  </header>

  <% pillar.sections.forEach((section) => { %>
    <section>
      <h2><%= section.heading %></h2>
      <% section.paragraphs.forEach((paragraph) => { %>
        <p><%= paragraph %></p>
      <% }) %>
      <% if (section.bullets && section.bullets.length) { %>
        <ul>
          <% section.bullets.forEach((bullet) => { %>
            <li><%= bullet %></li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  <% }) %>

  <section class="pillar-navigation">
    <h2>Navigation</h2>
    <div class="pillar-nav-links">
      <a class="button button-outline" href="/charte">Retour à la charte</a>
      <a class="button button-outline" href="/">Retour à l'accueil</a>
    </div>
    <div class="pillar-nav-links">
      <% if (previousPillar) { %>
        <a class="text-link" href="/piliers/<%= previousPillar.slug %>">← Pilier précédent</a>
      <% } %>
      <% if (nextPillar) { %>
        <a class="text-link" href="/piliers/<%= nextPillar.slug %>">Pilier suivant →</a>
      <% } %>
    </div>
    <h3>Voir les autres piliers</h3>
    <ul class="other-pillars-list">
      <% pillars.forEach((item) => { if (item.slug !== pillar.slug) { %>
        <li><a class="text-link" href="/piliers/<%= item.slug %>"><%= item.title %></a></li>
      <% } }) %>
    </ul>
  </section>
</article>

<%- include('partials/footer') %>
