<%- include('partials/header', { title: 'Union Citoyenne | Confirmation envoyée', bodyClass: 'page-adhere' }) %>

<section class="page-hero page-hero-compact">
  <div class="page-hero-copy">
    <p class="eyebrow">Confirmation</p>
    <h1>Confirmation envoyée</h1>
    <p class="hero-lead">Un email de confirmation vient d'être envoyé.</p>
    <p>Merci de cliquer sur le lien reçu pour valider votre adhésion.</p>
  </div>

  <aside class="hero-panel hero-panel-compact">
    <p class="panel-kicker">Participation</p>
    <h2><%= confirmedCount %> adhérents confirmés</h2>
    <a class="button button-outline" href="/">Retour à l'accueil</a>
  </aside>
</section>

<section class="content-stack">
  <article class="content-card supporter-block content-card-center">
    <p>La validation par email est nécessaire pour confirmer l'adhésion.</p>
    <p><a class="button" href="/charte">Voir la charte</a></p>
  </article>
</section>

<%- include('partials/footer') %>
