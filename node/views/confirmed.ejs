<%- include('partials/header', { title: 'Union Citoyenne | Adhesion confirmee', bodyClass: 'page-adhere' }) %>

<section class="page-hero page-hero-compact">
  <div class="page-hero-copy">
    <p class="eyebrow">Confirmation</p>
    <% if (status === 'already') { %>
      <h1>Adhesion deja confirmee</h1>
      <p class="hero-lead">Cette adresse email est deja confirmee comme adherente a la charte.</p>
    <% } else if (status === 'ok') { %>
      <h1>Adhesion confirmee</h1>
      <p class="hero-lead">Merci. Votre adhesion a la charte d'Union Citoyenne est maintenant confirmee.</p>
    <% } else { %>
      <h1>Lien invalide</h1>
      <p class="hero-lead">Le lien de confirmation est invalide ou expire.</p>
    <% } %>
  </div>

  <aside class="hero-panel hero-panel-compact">
    <p class="panel-kicker">Participation</p>
    <h2><%= confirmedCount %> adherents confirmes</h2>
    <a class="button button-outline" href="/">Retour a l'accueil</a>
  </aside>
</section>

<section class="content-stack">
  <article class="content-card supporter-block content-card-center">
    <p><strong>Le soutien confirme nourrit la dynamique du projet.</strong></p>
    <p><a class="button" href="/charte">Lire la charte</a></p>
  </article>
</section>

<%- include('partials/footer') %>
