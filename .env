NODE_ENV=development
PORT=3000
# Optional in production: if empty, app uses current request host for confirmation links
APP_BASE_URL=http://localhost:3000
APP_SECRET=change-me

# Use your PostgreSQL connection string
DATABASE_URL=postgresql://app:password@127.0.0.1:5432/union_citoyenne

# Mail setup (Resend)
# Option A: set RESEND_API_KEY directly
RESEND_API_KEY=
# Option B: or provide MAILER_DSN like: resend+api://YOUR_KEY@default
MAILER_DSN=
MAILER_FROM=no-reply@union-citoyenne.fr
MAILER_FROM_NAME=Union Citoyenne
MAILER_REPLY_TO=contact@union-citoyenne.fr

# Set true once to reset supporter table on next boot, then set back to false
RESET_SUPPORTERS_ON_BOOT=false
