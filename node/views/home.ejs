<%- include('partials/header', { title: 'Union Citoyenne | Accueil', bodyClass: 'page-home' }) %>

<section class="page-hero page-hero-home">
  <div class="page-hero-copy">
    <p class="eyebrow">Mouvement humaniste reformiste</p>
    <h1>Union Citoyenne</h1>
    <p class="hero-lead">
      Union Citoyenne veut depasser le clivage gauche-droite pour remettre au centre la dignite
      humaine, la responsabilite individuelle et la democratie locale.
    </p>
    <p>
      Notre objectif est simple: rendre l'action publique plus proche, plus juste et plus efficace,
      avec des citoyens pleinement acteurs dans les decisions qui touchent leur quotidien.
    </p>
    <div class="hero-actions">
      <a class="button" href="/charte">Decouvrir la charte</a>
      <a class="button button-outline" href="/adherer">Adherer</a>
    </div>
  </div>

  <aside class="hero-panel">
    <p class="panel-kicker">Cap politique</p>
    <h2>Redonner du poids aux citoyens et aux territoires</h2>
    <p>
      Une methode civique, des assemblees locales, une coordination territoriale
      et des piliers concrets pour transformer l'action publique.
    </p>
    <div class="metric-grid">
      <article class="metric-card">
        <strong><%= confirmedCount %></strong>
        <span>adherents confirmes</span>
      </article>
      <article class="metric-card">
        <strong>7</strong>
        <span>piliers de reforme</span>
      </article>
      <article class="metric-card">
        <strong>3</strong>
        <span>reperes fondateurs</span>
      </article>
    </div>
  </aside>
</section>

<section class="themed-section">
  <div class="section-heading">
    <p class="eyebrow">Notre methode</p>
    <h2>Trois repères pour structurer le projet</h2>
  </div>

  <div class="feature-grid">
    <article class="feature-card">
      <h3>Philosophie</h3>
      <p>Former des citoyens capables de penser par eux-memes et de juger avec recul.</p>
    </article>
    <article class="feature-card">
      <h3>Ethique</h3>
      <p>Relier liberte et responsabilite, avec une exigence de dignite pour chacun.</p>
    </article>
    <article class="feature-card">
      <h3>Institutions</h3>
      <p>Organiser des mecanismes clairs pour que les decisions reviennent aux citoyens.</p>
    </article>
  </div>
</section>

<section class="themed-section">
  <div class="section-heading">
    <p class="eyebrow">Fonctionnement</p>
    <h2>Une democratie qui remonte du terrain</h2>
  </div>

  <div class="timeline-grid">
    <article class="timeline-card">
      <span class="timeline-index">01</span>
      <h3>Assemblees locales</h3>
      <p>Une assemblee citoyenne hebdomadaire dans chaque commune pour debattre et proposer.</p>
    </article>
    <article class="timeline-card">
      <span class="timeline-index">02</span>
      <h3>Coordination regionale</h3>
      <p>Une coordination mensuelle par region pour consolider les priorites du terrain.</p>
    </article>
    <article class="timeline-card">
      <span class="timeline-index">03</span>
      <h3>Referendum national</h3>
      <p>Un referendum citoyen national pour les grands sujets qui engagent l'ensemble du pays.</p>
    </article>
  </div>
</section>

<section class="themed-section">
  <div class="section-heading">
    <p class="eyebrow">Piliers</p>
    <h2>Les axes du projet</h2>
  </div>

  <div class="pillar-grid">
    <% pillars.forEach((pillar) => { %>
      <article class="pillar-card">
        <img class="pillar-card-image" src="<%= pillar.icon %>" alt="Illustration <%= pillar.title %>" />
        <div class="pillar-card-body">
          <h3><%= pillar.title %></h3>
          <p><%= pillar.shortDescription %></p>
          <a class="text-link" href="/piliers/<%= pillar.slug %>">Decouvrir ce pilier</a>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="quote-band">
  <img src="/images/logo.png" alt="Logo Union Citoyenne" class="conclusion-logo" />
  <blockquote>Le peuple par le peuple. Le peuple pour le peuple.</blockquote>
  <p class="quote-note">Liberte de penser, liberte de changer, responsabilite individuelle.</p>
</section>

<section class="cta-banner">
  <div>
    <p class="eyebrow">Adhesion</p>
    <h2>Rejoindre la charte</h2>
    <p>Le projet compte deja <strong><%= confirmedCount %> adherents confirmes</strong>.</p>
  </div>
  <div class="cta-actions">
    <a class="button" href="/adherer">Adherer a la charte</a>
  </div>
</section>

<%- include('partials/footer') %>
